# Buscando informações de todas as suas instâncias ec2 em execução na sua conta AWS
aws ec2 describe-instances --query "Reservations[*].Instances[*].{ \
        \"1_Name\":Tags[?Key=='Name']|[0].Value, \
        \"2_Tipo\":InstanceType, \
        \"3_Zone\":Placement.AvailabilityZone, \
        \"4_PublicIP\":PublicIpAddress}" \
    --filters "Name=instance-state-name,Values=running" \
    --output table

